{
  "name": "@yoursign/web",
  "version": "0.1.0",
  "private": true,
  "description": "YourSign web app. Next.js 16 App Router. Deployed on Cloudflare Pages via @opennextjs/cloudflare.",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "deploy": "opennextjs-cloudflare build && wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "echo 'lint TODO — next 16 removed `next lint`; will wire eslint directly later'",
    "clean": "rm -rf .next dist .turbo .open-next"
  },
  "dependencies": {
    "@privy-io/react-auth": "^3.23.0",
    "@solana-program/memo": "^0.11.0",
    "@solana/kit": "^6.9.0",
    "@solana/wallet-adapter-base": "^0.9.23",
    "@solana/wallet-adapter-phantom": "^0.9.24",
    "@solana/wallet-adapter-react": "^0.15.35",
    "@solana/wallet-adapter-react-ui": "^0.9.35",
    "@solana/web3.js": "^1.95.0",
    "@yoursign/agent-sdk": "workspace:*",
    "@yoursign/crypto": "workspace:*",
    "@yoursign/pdf-engine": "workspace:*",
    "@yoursign/schemas": "workspace:*",
    "@yoursign/solana-sdk": "workspace:*",
    "@yoursign/ui": "workspace:*",
    "bs58": "^6.0.0",
    "next": "^16.0.0",
    "next-intl": "^4.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.86.0"
  }
}
