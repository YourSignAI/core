{
  "name": "@yoursign/solana-sdk",
  "version": "0.1.0",
  "description": "Anchor IDL bindings + Light Protocol read helpers + verify CLI.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "yoursign-verify": "./dist/bin/verify.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "echo 'lint TODO'",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@noble/hashes": "^1.6.0",
    "@solana/web3.js": "^1.95.0",
    "@yoursign/agent-sdk": "workspace:*",
    "@yoursign/crypto": "workspace:*",
    "@yoursign/core-domain": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
