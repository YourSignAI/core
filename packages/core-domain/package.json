{
  "name": "@yoursign/core-domain",
  "version": "0.1.0",
  "description": "Domain types: Submitter, Submission, Template, AgentDelegation. Pure TypeScript, no IO.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "echo 'lint TODO'",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@yoursign/schemas": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
