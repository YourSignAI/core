{
  "name": "yoursign-core",
  "private": true,
  "version": "0.0.0",
  "description": "YourSign — decentralized document signing on Solana. Public monorepo.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/YourSignAI/core"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --concurrency=20",
    "dev:web": "pnpm --filter @yoursign/web dev",
    "dev:verifier": "pnpm --filter @yoursign/verifier dev",
    "dev:api": "pnpm --filter @yoursign/api dev",
    "dev:mcp": "pnpm --filter @yoursign/mcp dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write .",
    "anchor:build": "cd programs/yoursign && anchor build",
    "anchor:test": "cd programs/yoursign && anchor test",
    "smoke": "bash scripts/smoke-test.sh",
    "setup:solana": "bash scripts/setup-solana.sh",
    "deploy:devnet": "bash scripts/deploy-devnet.sh",
    "init:tool-manifest": "tsx scripts/init-tool-manifest.ts"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/web3.js": "^1.95.0",
    "@types/node": "^22.10.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}
